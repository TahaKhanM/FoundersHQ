# Docker (default)
# DATABASE_URL=postgresql+asyncpg://foundershq:foundershq@db:5432/foundershq
# DATABASE_URL_SYNC=postgresql://foundershq:foundershq@db:5432/foundershq

# Local Postgres (copy to .env and use when running outside Docker)
DATABASE_URL=postgresql+asyncpg://foundershq:foundershq@localhost:5432/foundershq
DATABASE_URL_SYNC=postgresql://foundershq:foundershq@localhost:5432/foundershq

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
SECRET_KEY=dev-secret
OPENAI_API_KEY=